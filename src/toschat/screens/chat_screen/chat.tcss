NavbarWidget {
    layout: horizontal;
    height: 3;
    margin: 1;
    padding-top: 1;
    padding-bottom: 1;
    padding-left: 3;
    padding-right: 3;
    background: rgb(91, 81, 81);
}

#back-btn {
    dock: left;
    border: none;
    height: 1;
}

#logout-btn {
    dock: right;
    border: none;
    height: 1;
}

#another-username{
    content-align: center middle;
}